[Unit]
Description=BKCam PPPP camera dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/bkcam-server
ExecStart=/usr/bin/node /opt/bkcam-server/server.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
